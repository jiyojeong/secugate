  "scenarios": [
    {
      "id": "aws_initial_access_to_iam_abuse",
      "title": "공개 SSH 노출 후 IAM 권한 악용",
      "description": "공개 SSH 인바운드 노출 자산에 대한 초기 접근 이후, 관리자급/와일드카드 IAM 권한을 악용해 권한 상승 또는 지속성을 확보할 수 있음",
      "requires_capabilities": ["sg_ingress_ssh_open", "iam_policy_admin_or_wildcard"],
      "atomic_chain": ["T1190", "T1098.003"],
      "score": "high",
      "logic": "If an internet-exposed entry point (public SSH) exists AND privileged IAM permissions (admin/wildcard) are present on the same asset or its role, generate an IA→PE scenario."
    },
    {
      "id": "aws_credential_collection_and_exfiltration",
      "title": "IMDS 자격증명 수집 후 외부 유출",
      "description": "IMDSv1 활성화로 자격증명 수집이 쉬워지고, 전방위 egress 허용이 결합되면 외부 반출 위험이 증가함",
      "requires_capabilities": ["imdsv1_enabled", "sg_egress_all_open"],
      "atomic_chain": ["T1552", "T1041"],
      "score": "high",
      "logic": "If credentials can be harvested via IMDSv1 AND outbound traffic is unrestricted, generate a credential-collection→exfiltration scenario."
    },
    {
      "id": "aws_identity_persistence_via_iam_user",
      "title": "IAM 사용자 직접 정책 기반 지속성",
      "description": "IAM 사용자 존재 + 사용자 직접 정책 부여 + 권한상승 가능 정책이 결합되면 장기 자격증명 기반 지속성이 강화됨",
      "requires_capabilities": ["iam_user_present", "iam_policy_attached_to_user", "iam_policy_privilege_escalation"],
      "atomic_chain": ["T1078.004", "T1098.003"],
      "score": "high",
      "logic": "If long-lived IAM users exist AND policies are directly attached to users AND escalation paths exist, generate a persistence scenario."
    },
    {
      "id": "aws_visibility_gap_and_remote_access_risk",
      "title": "가시성 공백과 기본 SG 원격 접근 위험",
      "description": "VPC Flow Logs가 없고 기본 SG가 제한되지 않으면 원격 접근 시도 및 네트워크 활동에 대한 탐지/분석 공백이 커짐",
      "requires_capabilities": ["vpc_flow_logs_disabled", "default_sg_not_restricted"],
      "atomic_chain": ["T1046", "T1021"],
      "score": "medium",
      "logic": "If network visibility (flow logs) is absent AND default security group is permissive, raise the risk of undetected remote access and discovery activity."
    }
  ]
